# Injected automatically by Vercel's Neon integration.
# For local dev: copy to .env.local and fill in your Neon connection string.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Web Push (VAPID) — generate with: node -e "require('web-push').generateVAPIDKeys()" (after npm install web-push)
VAPID_PUBLIC_KEY=your_base64url_public_key
VAPID_PRIVATE_KEY=your_base64url_private_key
VAPID_EMAIL=you@example.com

# Telegram bot — token from BotFather; secret is any high-entropy string
# (e.g. `openssl rand -hex 32`) used to verify webhook authenticity.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
